<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<title>RP Verkaufsrechner</title>

<style>
body {
  background: #1e1e2f;
  color: white;
  font-family: Arial;
  text-align: center;
  padding: 40px;
}

.container {
  background: #2c2c3e;
  padding: 25px;
  border-radius: 12px;
  display: inline-block;
  min-width: 300px;
}

h1 {
  margin-bottom: 20px;
}

.item {
  margin: 10px 0;
}

input {
  padding: 8px;
  width: 80px;
  text-align: center;
  margin-left: 10px;
}

.result {
  margin-top: 20px;
  font-size: 20px;
}

</style>
</head>

<body>

<div class="container">
  <h1>RP Verkaufsrechner</h1>

  <div class="item">
    Wagyu Steak (250$):
    <input type="number" id="wagyu" value="0" oninput="berechnen()">
  </div>

  <div class="item">
    Zitronenwasser (50$):
    <input type="number" id="wasser" value="0" oninput="berechnen()">
  </div>

  <div class="item">
    Rotwein (100$):
    <input type="number" id="wein" value="0" oninput="berechnen()">
  </div>

  <div class="item">
    Panna Cotta (75$):
    <input type="number" id="panna" value="0" oninput="berechnen()">
  </div>

  <hr>

  <div class="item">
    Rabatt (%):
    <input type="number" id="rabatt" value="0" oninput="berechnen()">
  </div>

  <div class="result" id="gesamt">Gesamt: 0$</div>
  <div class="result" id="endpreis">Endpreis: 0$</div>

</div>

<script>
function berechnen() {
  let wagyu = document.getElementById("wagyu").value * 250;
  let wasser = document.getElementById("wasser").value * 50;
  let wein = document.getElementById("wein").value * 100;
  let panna = document.getElementById("panna").value * 75;

  let gesamt = wagyu + wasser + wein + panna;

  let rabatt = document.getElementById("rabatt").value;
  let endpreis = gesamt - (gesamt * rabatt / 100);

  document.getElementById("gesamt").innerText = "Gesamt: " + gesamt + "$";
  document.getElementById("endpreis").innerText = "Endpreis: " + endpreis.toFixed(2) + "$";
}
</script>

</body>
</html>
